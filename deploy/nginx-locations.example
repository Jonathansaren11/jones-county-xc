# Example Nginx directives for Jones County XC (merge into your EXISTING
# HTTPS server { } block for your domain — do not replace the whole file).
#
# Prerequisites on the server:
#   - Static files live at: /var/www/jones-county-xc/  (same as GitHub Actions rsync target)
#   - Go backend listens on: 127.0.0.1:8080  (systemd service xc-backend)
#
# Merge steps:
#   1. sudo nano /etc/nginx/sites-available/your-site   # or conf.d/your-site.conf
#   2. Inside the server { ... } that has ssl_certificate for your domain, set:
#        root /var/www/jones-county-xc;
#        index index.html;
#   3. Add the location blocks below (order: /api before catch-all /).
#   4. sudo nginx -t && sudo systemctl reload nginx
#
# If you already have `root` and `index` for this site, only add/adjust locations.

    # API → Go backend
    location /api/ {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # React SPA: real files first, then index.html for client-side routes
    location / {
        try_files $uri $uri/ /index.html;
    }
