# Copy to the server (e.g. /etc/xc-backend.env), chmod 600, owned by root.
# Reference this file from the systemd unit (see xc-backend.service.override.example).
#
# Required for POST /api/login:
ADMIN_PASSWORD=change-me-to-a-long-random-secret
#
# Existing backend vars (adjust for your MySQL):
DB_USER=
DB_PASSWORD=
DB_NAME=jones_county_xc
DB_HOST=127.0.0.1:3306
